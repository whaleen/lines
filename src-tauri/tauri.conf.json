{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "lines",
  "version": "0.1.0",
  "identifier": "com.whaleen.lines",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "vp dev --host 0.0.0.0 --port 1420 --strictPort",
    "beforeBuildCommand": "vp build"
  },
  "app": {
    "windows": [
      {
        "title": "lines",
        "width": 1440,
        "height": 920,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
