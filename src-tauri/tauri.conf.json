{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "lines",
  "version": "0.2.2",
  "identifier": "com.whaleen.lines",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "vp dev --host 0.0.0.0 --port 1420 --strictPort",
    "beforeBuildCommand": "vp build"
  },
  "app": {
    "windows": [
      {
        "title": "lines",
        "width": 1440,
        "height": 920,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0NDgzNkZFNUY2OTg5QTcKUldTbmlXbGYvalpJRlBIeVlIWDZuaGxLUHBQWXl0VG1vMTF3L1MrZkkrUzRPaFZ3RWJTYU1EMFkK",
      "endpoints": [
        "https://raw.githubusercontent.com/whaleen/homebrew-tap/main/latest.json"
      ]
    }
  }
}
